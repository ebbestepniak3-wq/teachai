{
  "name": "teachai",
  "version": "1.0.0",
  "description": "TeacherAI – KI-gestützte Korrekturplattform für Lehrkräfte in Deutschland",
  "private": true,
  "scripts": {
    "build": "cd apps/web && next build",
    "dev": "cd apps/web && next dev",
    "lint": "cd apps/web && next lint",
    "test": "echo no tests",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "type-check": "echo ok",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:migrate": "cd packages/database && npx prisma migrate dev",
    "db:migrate:prod": "cd packages/database && npx prisma migrate deploy",
    "db:push": "cd packages/database && npx prisma db push",
    "db:studio": "cd packages/database && npx prisma studio",
    "db:seed": "cd packages/database && npx tsx seed.ts",
    "clean": "echo ok"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.5.0",
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0",
    "lucide-react": "^0.383.0",
    "next-themes": "^0.2.1",
    "tailwindcss-animate": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-toast": "^1.1.5",
    "@prisma/client": "^5.22.0"
  }
}