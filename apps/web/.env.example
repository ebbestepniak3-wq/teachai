# ═══════════════════════════════════════════════════════
# TeacherAI – Umgebungsvariablen
# Kopieren Sie diese Datei zu .env.local und befüllen Sie sie.
# ═══════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Datenbank (Supabase / PostgreSQL) ────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/teachai?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/teachai?sslmode=require

# ── JWT Auth ─────────────────────────────────────────────
# Generieren mit: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-different-from-above

# ── Anthropic Claude API ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase Storage ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe Payments ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (aus Stripe Dashboard)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_MAX_PRO=price_...

# ── Redis (Upstash) für Rate Limiting & Queue ─────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── E-Mail (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=TeacherAI <noreply@teachai.de>

# ── OAuth (optional) ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Cloudflare (optional) ────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ── Cron Jobs ─────────────────────────────────────────────
# Secret for protecting cron job endpoints
CRON_SECRET=your-cron-secret-min-32-chars

# ── Monitoring ────────────────────────────────────────────
# Bearer token for /api/metrics endpoint
METRICS_TOKEN=your-metrics-token-min-32-chars

# ── Stripe Yearly Prices (optional) ──────────────────────
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_MAX_PRO_YEARLY=price_...

# ── Google Search Console ─────────────────────────────────
GOOGLE_SITE_VERIFICATION=

# ── Build ─────────────────────────────────────────────────
BUILD_VERSION=dev
