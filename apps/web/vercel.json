{
  "crons": [
    {
      "path": "/api/cron/cleanup-uploads",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "app/api/upload/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/upload/ocr/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    },
    "app/api/grading/execute/route.ts": {
      "maxDuration": 300
    },
    "app/api/grading/pdf/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/assistant/chat/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/cleanup-uploads/route.ts": {
      "maxDuration": 120
    },
    "app/api/stripe/webhook/route.ts": {
      "maxDuration": 30
    }
  }
}
